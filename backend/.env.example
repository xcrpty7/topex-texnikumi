# ════════════════════════════════════════════════════════════════════
# Topex Backend — Local .env namuna
# Quyidagini `.env` deb saqlang va o'z qiymatlaringizni yozing
# ════════════════════════════════════════════════════════════════════

NODE_ENV=development
PORT=10000

# MongoDB Atlas (https://cloud.mongodb.com/) yoki local MongoDB ulanish URI
MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/topex?retryWrites=true

# JWT sirlari (har qanday uzun random string)
JWT_ACCESS_SECRET=change-me-to-long-random-string-1
JWT_REFRESH_SECRET=change-me-to-long-random-string-2
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Frontend manzili (CORS uchun)
CLIENT_URL=http://localhost:3000

# Fayl yuklash hajmi (bytes, default 5MB)
MAX_FILE_SIZE=26214400

# Birinchi Super Admin (server birinchi marta ishga tushganda yaratiladi)
ADMIN_EMAIL=admin@topex.uz
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NAME=Super Admin
