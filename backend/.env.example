# ════════════════════════════════════════════════════════════════════
# Topex Backend — Local .env namuna
# Quyidagini `.env` deb saqlang va o'z qiymatlaringizni yozing
# ════════════════════════════════════════════════════════════════════

NODE_ENV=development
PORT=10000

# MongoDB Atlas (https://cloud.mongodb.com/) yoki local MongoDB ulanish URI
MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/topex?retryWrites=true

# JWT sirlari (har qanday uzun random string)
JWT_ACCESS_SECRET=change-me-to-long-random-string-1
JWT_REFRESH_SECRET=change-me-to-long-random-string-2
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Frontend manzili (CORS uchun)
CLIENT_URL=http://localhost:3000

# Fayl yuklash hajmi (bytes, default 5MB)
MAX_FILE_SIZE=26214400

# Birinchi Super Admin (server birinchi marta ishga tushganda yaratiladi)
ADMIN_EMAIL=admin@topex.uz
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NAME=Super Admin

# ════════════════════════════════════════════════════════════════════
# AmoCRM API v4 (для добавления тегов к лидам с сайта)
# ════════════════════════════════════════════════════════════════════
# 1. В AmoCRM → Настройки → API → Создайте интеграцию (Private OAuth2)
# 2. Укажите Redirect URI = AMOCRM_REDIRECT_URI
# 3. Запустите сервер и откройте /api/amocrm/auth
# 4. После авторизации токены сохранятся автоматически
# ════════════════════════════════════════════════════════════════════
AMOCRM_SUBDOMAIN=your-subdomain                    # Без .amocrm.ru — просто "mycompany"
AMOCRM_CLIENT_ID=your-client-id                    # Client ID из настроек интеграции
AMOCRM_CLIENT_SECRET=your-client-secret            # Client Secret из настроек интеграции
AMOCRM_REDIRECT_URI=https://your-backend.onrender.com/api/amocrm/callback
